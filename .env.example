# Core services
DATABASE_URL=postgresql://jobfill:jobfill@postgres:5432/jobfill
REDIS_URL=redis://redis:6379/0

# Google OAuth (Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# NextAuth.js
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32-output
NEXTAUTH_URL=https://jobs.zoommate.in

# Frontend -> backend API URL
NEXT_PUBLIC_API_URL=https://jobs.zoommate.in/api

# File uploads
UPLOAD_DIR=/backend/uploads

# Encrypting AI keys in DB
ENCRYPTION_KEY=replace-with-32-byte-base64-or-hex-key

# AI providers
OPENAI_API_KEY=your-openai-api-key
GEMINI_API_KEY=your-gemini-api-key
DEFAULT_AI_PROVIDER=openai
