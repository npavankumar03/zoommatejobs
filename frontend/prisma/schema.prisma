generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  EXPERT
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
}

enum WorkMode {
  REMOTE
  HYBRID
  ONSITE
}

enum AtsType {
  GREENHOUSE
  LEVER
  WORKDAY
  ICIMS
  OTHER
}

enum ApplicationStatus {
  SAVED
  APPLIED
  INTERVIEW
  OFFER
  REJECTED
}

enum AiProvider {
  OPENAI
  GEMINI
}

enum ScraperRunStatus {
  SUCCESS
  PARTIAL
  FAILED
}

enum AiUsageAction {
  FORM_FILL
  RESUME_TUNE
  COVER_LETTER
  IDENTIFY_FIELDS
}

model User {
  id                   String       @id @default(uuid()) @db.Uuid
  googleId             String       @unique
  email                String       @unique
  emailVerified        DateTime?
  fullName             String?
  phone                String?
  location             String?
  image                String?
  linkedinUrl          String?
  githubUrl            String?
  portfolioUrl         String?
  websiteUrl           String?
  expectedSalary       Int?
  workAuthorization    String?
  requiresSponsorship  Boolean      @default(false)
  willingToRelocate    Boolean      @default(false)
  totalYearsExperience Int?
  personalBio          String?      @db.Text
  resumeSummary        String?      @db.Text
  resumeText           String?      @db.Text
  resumeFileName       String?
  resumeFilePath       String?
  isAdmin              Boolean      @default(false)
  isBanned             Boolean      @default(false)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  accounts             Account[]
  sessions             Session[]
  workHistory          WorkHistory[]
  education            Education[]
  skills               Skill[]
  applications         Application[]
  savedJobs            SavedJob[]
  aiUsageLogs          AiUsageLog[]
}

model Account {
  id                String  @id @default(uuid()) @db.Uuid
  userId            String  @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique
  userId       String   @db.Uuid
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@unique([token])
}

model WorkHistory {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  company      String
  title        String
  location     String?
  startDate    DateTime
  endDate      DateTime?
  isCurrent    Boolean  @default(false)
  description  String?  @db.Text
  technologies String[] @default([])
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Education {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @db.Uuid
  school         String
  degree         String
  fieldOfStudy   String?
  graduationYear Int?
  gpa            String?
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Skill {
  id        String     @id @default(uuid()) @db.Uuid
  userId    String     @db.Uuid
  name      String
  level     SkillLevel
  createdAt DateTime   @default(now())
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Job {
  id            String        @id @default(uuid()) @db.Uuid
  title         String
  company       String
  location      String?
  description   String        @db.Text
  requirements  String?       @db.Text
  salary        String?
  jobType       JobType
  workMode      WorkMode
  sourceUrl     String        @unique
  atsType       AtsType
  isActive      Boolean       @default(true)
  isSponsorsH1B Boolean       @default(false)
  postedAt      DateTime?
  scrapedAt     DateTime?
  expiresAt     DateTime?
  createdAt     DateTime      @default(now())
  applications  Application[]
  savedBy       SavedJob[]
}

model Application {
  id           String            @id @default(uuid()) @db.Uuid
  userId       String            @db.Uuid
  jobId        String            @db.Uuid
  status       ApplicationStatus @default(SAVED)
  appliedAt    DateTime?
  notes        String?           @db.Text
  aiFilledData Json?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  job          Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([jobId])
}

model SavedJob {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  jobId     String   @db.Uuid
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId])
  @@index([jobId])
}

model AdminSettings {
  id                   String     @id @default("global")
  activeAiProvider     AiProvider @default(OPENAI)
  openaiApiKey         String?
  openaiModel          String     @default("gpt-4o")
  geminiApiKey         String?
  geminiModel          String     @default("gemini-1.5-pro")
  maxFreeAiFillsPerDay Int        @default(10)
  scraperEnabled       Boolean    @default(true)
  scraperIntervalHours Int        @default(6)
  allowRegistration    Boolean    @default(true)
  maintenanceMode      Boolean    @default(false)
  siteName             String     @default("zoommate")
  siteTagline          String?
  updatedAt            DateTime   @updatedAt
}

model ScraperLog {
  id              String           @id @default(uuid()) @db.Uuid
  runAt           DateTime         @default(now())
  totalNew        Int              @default(0)
  totalUpdated    Int              @default(0)
  totalExpired    Int              @default(0)
  durationSeconds Int?
  status          ScraperRunStatus
  errorLog        String?          @db.Text
}

model AiUsageLog {
  id         String        @id @default(uuid()) @db.Uuid
  userId     String        @db.Uuid
  action     AiUsageAction
  provider   AiProvider
  model      String
  tokensUsed Int?
  createdAt  DateTime      @default(now())
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
